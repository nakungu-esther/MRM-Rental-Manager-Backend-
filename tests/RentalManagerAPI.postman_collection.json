        },
        {
          "name": "List Leases",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{access_token}}"}],
            "url": {"raw": "{{base_url}}/leases/", "host": ["{{base_url}}"], "path": ["leases",""]}
          }
        },
        {
          "name": "Terminate Lease",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"reason\":\"Tenant moving out\",\"end_date\":\"2025-06-30\"}"
            },
            "url": {"raw": "{{base_url}}/leases/{{lease_id}}/terminate", "host": ["{{base_url}}"], "path": ["leases","{{lease_id}}","terminate"]}
          }
        }
      ]
    },
    {
      "name": "6. Invoices",
      "item": [
        {
          "name": "Create Invoice",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{access_token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"lease_id\":{{lease_id}},\"tenant_id\":{{tenant_id}},\"period_month\":1,\"period_year\":2025,\"due_date\":\"2025-01-05\",\"rent_amount\":1200.00,\"penalty_amount\":0,\"discount_amount\":0,\"description\":\"January 2025 Rent\"}"
            },
            "url": {"raw": "{{base_url}}/invoices/", "host": ["{{base_url}}"], "path": ["invoices",""]}
