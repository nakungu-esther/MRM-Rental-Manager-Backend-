            ],
            "body": {
              "mode": "raw",
              "raw": "{\"amount\":600.00,\"payment_method\":\"bank_transfer\",\"payment_date\":\"2025-01-03\",\"notes\":\"Partial payment\"}"
            },
            "url": {"raw": "{{base_url}}/invoices/{{invoice_id}}/pay", "host": ["{{base_url}}"], "path": ["invoices","{{invoice_id}}","pay"]}
