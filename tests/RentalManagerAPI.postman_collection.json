              "raw": "{\"tenant_id\":{{tenant_id}},\"unit_id\":{{unit_id}},\"start_date\":\"2025-01-01\",\"end_date\":\"2025-12-31\",\"monthly_rent\":1200.00,\"deposit_amount\":1200.00,\"deposit_paid\":true}"
            },
            "url": {"raw": "{{base_url}}/leases/", "host": ["{{base_url}}"], "path": ["leases",""]}
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "var jsonData = pm.response.json();",
