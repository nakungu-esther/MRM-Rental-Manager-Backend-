# Database (Neon — must include ?sslmode=require on the connection string)
DATABASE_URL=postgresql://neondb_owner:npg_hlX6K7mRTQHj@ep-misty-frost-apzmubj1-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
ENVIRONMENT=development
# Faster uvicorn reload after first boot (migrations already applied). Delete .startup_migrations.stamp if schema changes.
# SKIP_STARTUP_MIGRATIONS=true

# Offline local dev only (no Neon): uncomment and run: python -m app.utils.init_db
# DATABASE_URL=sqlite:///./rental_local.db
# DATABASE_SCHEMA=public

FRONTEND_BASE_URL=https://your-app.example.com
API_PUBLIC_BASE_URL=https://api.your-app.example.com

# ── Uganda payments (pick ONE provider) ──

# A) MTN MoMo Collection API (MTN phones only) — https://momodeveloper.mtn.com
PAYMENT_GATEWAY_PROVIDER=mtn_momo
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_TARGET_ENVIRONMENT=mtnuganda
MTN_MOMO_BASE_URL=https://proxy.momoapi.mtn.com
MTN_MOMO_CALLBACK_URL=https://api.your-app.example.com/api/v1/payments/webhooks/mtn-momo

# B) Pesapal (MTN + Airtel + card) — https://www.pesapal.com/ug/
# PAYMENT_GATEWAY_PROVIDER=pesapal
# PESAPAL_CONSUMER_KEY=
# PESAPAL_CONSUMER_SECRET=
# PESAPAL_ENV=live
# PESAPAL_IPN_ID=

PAYMENT_ALLOW_MOCK=false

# C) Sui blockchain (hybrid — works alongside Pesapal/MTN; does not replace fiat)
SUI_NETWORK=devnet
SUI_RPC_URL=https://fullnode.devnet.sui.io:443
SUI_TREASURY_ADDRESS=
SUI_PACKAGE_ID=
SUI_ESCROW_MODULE=escrow
SUI_UGX_PER_SUI=6000000
SUI_ANCHOR_FIAT_RECEIPTS=true
WALRUS_PUBLISHER_URL=
WALRUS_AGGREGATOR_URL=

# ── Email (registration, password reset, government officer invitations) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=RentDirect UG <your-email@gmail.com>
EMAIL_BRAND_NAME=RentDirect UG
EMAIL_PRODUCT_TAGLINE=Property rentals · Uganda
# Optional HTTPS logo URL. If empty, emails embed app/static/brand/uganda-coat-of-arms.png (same as web app).
EMAIL_BRAND_LOGO_URL=
EMAIL_SUPPORT_EMAIL=
