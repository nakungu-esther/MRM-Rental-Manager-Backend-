# Database
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/rental_manager_db?sslmode=require
ENVIRONMENT=production

FRONTEND_BASE_URL=https://your-app.example.com
API_PUBLIC_BASE_URL=https://api.your-app.example.com

# ── Uganda payments (pick ONE provider) ──

# A) MTN MoMo Collection API (MTN phones only) — https://momodeveloper.mtn.com
PAYMENT_GATEWAY_PROVIDER=mtn_momo
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_TARGET_ENVIRONMENT=mtnuganda
MTN_MOMO_BASE_URL=https://proxy.momoapi.mtn.com
MTN_MOMO_CALLBACK_URL=https://api.your-app.example.com/api/v1/payments/webhooks/mtn-momo

# B) Pesapal (MTN + Airtel + card) — https://www.pesapal.com/ug/
# PAYMENT_GATEWAY_PROVIDER=pesapal
# PESAPAL_CONSUMER_KEY=
# PESAPAL_CONSUMER_SECRET=
# PESAPAL_ENV=live
# PESAPAL_IPN_ID=

PAYMENT_ALLOW_MOCK=false
